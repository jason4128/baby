{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user's tools, settings, and profile info",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The user ID" },
        "nickname": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "role": { "type": "string", "enum": ["mama", "papa", "guest"] },
        "isGuest": { "type": "boolean" },
        "tools": { "type": "array", "items": { "type": "string" } },
        "seasonings": { "type": "array", "items": { "type": "string" } },
        "ingredients": { "type": "array", "items": { "type": "string" } },
        "conceptionDate": { "type": "string", "format": "date-time" },
        "oauthClientId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "createdAt", "updatedAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "Comments on baby records",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "nickname": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "role": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "text", "createdAt"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "Messages in the shared chatroom",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "nickname": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "role": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "text", "createdAt"]
    },
    "Recipe": {
      "title": "Recipe",
      "description": "Stores saved recipes",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "ingredients": { "type": "array", "items": { "type": "object", "properties": {"name": {"type":"string"}, "amount": {"type":"string"}, "icon": {"type":"string"}} } },
        "steps": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "createdAt", "updatedAt"]
    },
    "BabyRecord": {
      "title": "Baby Record",
      "description": "Stores logs and media for the baby",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["image", "video", "text"] },
        "url": { "type": "string" },
        "note": { "type": "string" },
        "weekCount": { "type": "number" },
        "dayCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "date", "type", "createdAt"]
    },
    "ShoppingItem": {
      "title": "Shopping Item",
      "description": "Stores items to buy",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "isPurchased": { "type": "boolean" },
        "suggestedWeek": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "isPurchased", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile containing tools and ingredients"
    },
    "recipes/{recipeId}": {
      "schema": "Recipe",
      "description": "Recipes saved by the user"
    },
    "records/{recordId}": {
      "schema": "BabyRecord",
      "description": "Baby growth records"
    },
    "records/{recordId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Comments on a baby record"
    },
    "chatMessages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Shared chatroom messages"
    },
    "shoppingItems/{itemId}": {
      "schema": "ShoppingItem",
      "description": "Shopping list items"
    }
  }
}
