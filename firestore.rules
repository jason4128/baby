rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if isAdmin();
      allow read, write: if false;
    }

    // Primitive Helpers
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isGuest() { 
      // anonymous users or users with isGuest flag in their profile
      return isSignedIn() && (request.auth.token.firebase.sign_in_provider == 'anonymous');
    }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.uid == '9fJCbAnrFGeaG8IAOsUcp3XeUcf2' || 
        request.auth.token.get('email', '') == 'jason2134@gmail.com' || 
        request.auth.token.get('email', '') == 'user@gmail.com'
      ); 
    }

    // UserProfile Validations
    function isValidUserProfile(data) {
      return data.keys().hasAll(['userId', 'createdAt', 'updatedAt']) 
        && data.userId == request.auth.uid
        && data.userId is string && data.userId.size() <= 128
        && data.createdAt is timestamp
        && data.updatedAt is timestamp
        && ( !('nickname' in data) || (data.nickname is string && data.nickname.size() <= 50) )
        && ( !('avatarUrl' in data) || (data.avatarUrl is string && data.avatarUrl.size() <= 500) )
        && ( !('role' in data) || (data.role is string && data.role in ['mama', 'papa', 'guest']) )
        && ( !('isGuest' in data) || data.isGuest is bool )
        && ( !('tools' in data) || (data.tools is list && data.tools.size() <= 100) )
        && ( !('seasonings' in data) || (data.seasonings is list && data.seasonings.size() <= 100) )
        && ( !('ingredients' in data) || (data.ingredients is list && data.ingredients.size() <= 200) )
        && ( !('conceptionDate' in data) || data.conceptionDate is string )
        && ( !('oauthClientId' in data) || (data.oauthClientId is string && data.oauthClientId.size() <= 500) );
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (isAdmin() || request.auth.uid == userId || isGuest()) && isValidId(userId);
      allow create: if isSignedIn() && request.auth.uid == userId && isValidId(userId)
                    && isValidUserProfile(incoming())
                    && incoming().createdAt == request.time
                    && incoming().updatedAt == request.time;
      allow update: if isSignedIn() && (isAdmin() || request.auth.uid == userId) && isValidId(userId)
                    && isValidUserProfile(incoming())
                    && incoming().createdAt == existing().createdAt
                    && incoming().updatedAt == request.time
                    && incoming().diff(existing()).affectedKeys().hasOnly(['nickname', 'avatarUrl', 'role', 'isGuest', 'tools', 'seasonings', 'ingredients', 'conceptionDate', 'oauthClientId', 'updatedAt']);
    }

    // Recipe Validations
    function isValidRecipe(data) {
      return data.keys().hasAll(['userId', 'title', 'createdAt', 'updatedAt'])
        && data.userId is string // can be shared
        && data.title is string && data.title.size() <= 100
        && data.createdAt is timestamp
        && data.updatedAt is timestamp
        && ( !('category' in data) || (data.category is string && data.category.size() <= 50) )
        && ( !('description' in data) || (data.description is string && data.description.size() <= 1000) )
        && ( !('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() <= 500) )
        && ( !('ingredients' in data) || (data.ingredients is list && data.ingredients.size() <= 50) )
        && ( !('steps' in data) || (data.steps is list && data.steps.size() <= 50) );
    }

    match /recipes/{recipeId} {
      allow get: if isSignedIn() && isValidId(recipeId);
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isAdmin() && isValidId(recipeId)
                    && isValidRecipe(incoming())
                    && incoming().createdAt == request.time
                    && incoming().updatedAt == request.time;
      allow update: if isSignedIn() && isAdmin() && isValidId(recipeId)
                    && isValidRecipe(incoming())
                    && incoming().createdAt == existing().createdAt
                    && incoming().updatedAt == request.time
                    && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'category', 'description', 'imageUrl', 'ingredients', 'steps', 'updatedAt']);
      allow delete: if isSignedIn() && isAdmin() && isValidId(recipeId);
    }

    // BabyRecord Validations
    function isValidBabyRecord(data) {
      return data.keys().hasAll(['userId', 'date', 'type', 'createdAt'])
        && data.userId is string
        && data.date is string && data.date.size() <= 60
        && data.type is string && data.type in ['image', 'video', 'text']
        && data.createdAt is timestamp
        && ( !('url' in data) || (data.url is string && data.url.size() <= 1000000) )
        && ( !('driveFileId' in data) || (data.driveFileId is string && data.driveFileId.size() <= 500) )
        && ( !('note' in data) || (data.note is string && data.note.size() <= 2000) )
        && ( !('weekCount' in data) || data.weekCount is number )
        && ( !('dayCount' in data) || data.dayCount is number );
    }

    match /records/{recordId} {
      allow get: if isSignedIn() && isValidId(recordId);
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isAdmin() && isValidId(recordId)
                    && isValidBabyRecord(incoming())
                    && incoming().createdAt == request.time;
      allow update: if isSignedIn() && isAdmin() && isValidId(recordId)
                    && isValidBabyRecord(incoming())
                    && incoming().userId == existing().userId
                    && incoming().createdAt == existing().createdAt
                    && incoming().diff(existing()).affectedKeys().hasOnly(['date', 'note', 'url', 'driveFileId', 'weekCount', 'dayCount']);
      allow delete: if isSignedIn() && isAdmin() && isValidId(recordId);
    }

    // Comment Validations
    function isValidComment(data) {
      return data.keys().hasAll(['userId', 'text', 'createdAt'])
        && data.userId == request.auth.uid
        && data.text is string && data.text.size() <= 500
        && data.createdAt is timestamp
        && ( !('nickname' in data) || (data.nickname is string && data.nickname.size() <= 50) )
        && ( !('avatarUrl' in data) || (data.avatarUrl is string && data.avatarUrl.size() <= 500) )
        && ( !('role' in data) || (data.role is string && data.role.size() <= 20) );
    }

    match /records/{recordId}/comments/{commentId} {
      allow list, get: if isSignedIn() && isValidId(recordId);
      allow create: if isSignedIn() && isValidId(recordId) && isValidId(commentId)
                    && isValidComment(incoming())
                    && incoming().createdAt == request.time;
      allow delete: if isSignedIn() && (isAdmin() || existing().userId == request.auth.uid);
    }

    // ChatMessage Validations
    function isValidChatMessage(data) {
      return data.keys().hasAll(['userId', 'text', 'createdAt'])
        && data.userId == request.auth.uid
        && data.text is string && data.text.size() <= 1000
        && data.createdAt is timestamp
        && ( !('nickname' in data) || (data.nickname is string && data.nickname.size() <= 50) )
        && ( !('avatarUrl' in data) || (data.avatarUrl is string && data.avatarUrl.size() <= 500) )
        && ( !('role' in data) || (data.role is string && data.role.size() <= 20) );
    }

    match /chatMessages/{messageId} {
      allow list, get: if isSignedIn();
      allow create: if isSignedIn() && isValidId(messageId)
                    && isValidChatMessage(incoming())
                    && incoming().createdAt == request.time;
      allow delete: if isSignedIn() && (isAdmin() || existing().userId == request.auth.uid);
    }

    // ShoppingItem Validations
    function isValidShoppingItem(data) {
      return data.keys().hasAll(['userId', 'name', 'isPurchased', 'createdAt', 'updatedAt'])
        && data.userId == request.auth.uid
        && data.name is string && data.name.size() <= 100
        && data.isPurchased is bool
        && data.createdAt is timestamp
        && data.updatedAt is timestamp
        && ( !('category' in data) || (data.category is string && data.category.size() <= 50) )
        && ( !('suggestedWeek' in data) || data.suggestedWeek is number );
    }

    match /shoppingItems/{itemId} {
      allow get: if isSignedIn() && (isAdmin() || existing().userId == request.auth.uid) && isValidId(itemId);
      allow list: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && isValidId(itemId)
                    && isValidShoppingItem(incoming())
                    && incoming().createdAt == request.time
                    && incoming().updatedAt == request.time;
      allow update: if isSignedIn() && (isAdmin() || existing().userId == request.auth.uid) && isValidId(itemId)
                    && isValidShoppingItem(incoming())
                    && incoming().createdAt == existing().createdAt
                    && incoming().updatedAt == request.time
                    && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'category', 'isPurchased', 'suggestedWeek', 'updatedAt']);
      allow delete: if isSignedIn() && (isAdmin() || existing().userId == request.auth.uid) && isValidId(itemId);
    }

    // WifeNote Validations
    function isValidWifeNote(data) {
      return data.keys().hasAll(['userId', 'type', 'content', 'createdAt'])
        && data.userId == request.auth.uid
        && data.type is string && data.type.size() <= 20
        && data.content is string && data.content.size() <= 2000
        && data.createdAt is timestamp;
    }

    match /wife_notes/{noteId} {
      allow get: if isSignedIn() && (isAdmin() || existing().userId == request.auth.uid) && isValidId(noteId);
      allow list: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && isValidId(noteId)
                    && isValidWifeNote(incoming())
                    && incoming().createdAt == request.time;
      allow delete: if isSignedIn() && (isAdmin() || existing().userId == request.auth.uid) && isValidId(noteId);
    }

    // Milestone Validations
    function isValidMilestone(data) {
      return data.keys().hasAll(['userId', 'task', 'isCompleted', 'createdAt', 'updatedAt'])
        && data.userId == request.auth.uid
        && data.task is string && data.task.size() <= 200
        && data.isCompleted is bool
        && data.createdAt is timestamp
        && data.updatedAt is timestamp
        && ( !('category' in data) || (data.category is string && data.category.size() <= 50) );
    }

    match /milestones/{milestoneId} {
      allow get: if isSignedIn() && (isAdmin() || existing().userId == request.auth.uid) && isValidId(milestoneId);
      allow list: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && isValidId(milestoneId)
                    && isValidMilestone(incoming())
                    && incoming().createdAt is timestamp // we might be creating backdated ones in import
                    && incoming().updatedAt == request.time;
      allow update: if isSignedIn() && (isAdmin() || existing().userId == request.auth.uid) && isValidId(milestoneId)
                    && isValidMilestone(incoming())
                    && incoming().createdAt == existing().createdAt
                    && incoming().updatedAt == request.time
                    && incoming().diff(existing()).affectedKeys().hasOnly(['task', 'category', 'isCompleted', 'updatedAt']);
      allow delete: if isSignedIn() && (isAdmin() || existing().userId == request.auth.uid) && isValidId(milestoneId);
    }

    // PostpartumCenter Validations
    function isValidPostpartumCenter(data) {
      return data.keys().hasAll(['userId', 'name', 'location', 'price', 'medicalCare', 'environment', 'meals', 'extraServices', 'parking', 'neighborhood', 'commuteTime', 'summary', 'createdAt'])
        && data.userId == request.auth.uid
        && data.name is string && data.name.size() <= 200
        && data.location is string && data.location.size() <= 500
        && data.price is string && data.price.size() <= 500
        && data.medicalCare is string && data.medicalCare.size() <= 2000
        && data.environment is string && data.environment.size() <= 2000
        && data.meals is string && data.meals.size() <= 2000
        && data.extraServices is string && data.extraServices.size() <= 2000
        && data.parking is string && data.parking.size() <= 2000
        && data.neighborhood is string && data.neighborhood.size() <= 2000
        && data.commuteTime is string && data.commuteTime.size() <= 2000
        && data.summary is string && data.summary.size() <= 2000
        && data.createdAt is timestamp;
    }

    function isValidPostpartumEvaluation(data) {
      return data.keys().hasAll(['userId', 'name', 'result', 'createdAt'])
        && data.userId == request.auth.uid
        && data.name is string && data.name.size() <= 200
        && data.result is string && data.result.size() <= 200
        && data.createdAt is timestamp;
    }

    match /postpartum_centers/{centerId} {
      allow get: if isSignedIn() && (isAdmin() || existing().userId == request.auth.uid) && isValidId(centerId);
      allow list: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && isValidId(centerId)
                    && isValidPostpartumCenter(incoming())
                    && incoming().createdAt == request.time;
      allow update: if isSignedIn() && isValidId(centerId)
                    && (isAdmin() || existing().userId == request.auth.uid)
                    && isValidPostpartumCenter(incoming())
                    && incoming().userId == existing().userId
                    && incoming().createdAt == existing().createdAt;
      allow delete: if isSignedIn() && (isAdmin() || existing().userId == request.auth.uid) && isValidId(centerId);
    }
    
    match /postpartum_evaluations/{evalId} {
      allow get: if isSignedIn() && (isAdmin() || existing().userId == request.auth.uid) && isValidId(evalId);
      allow list: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && isValidId(evalId)
                    && isValidPostpartumEvaluation(incoming())
                    && incoming().createdAt == request.time;
      allow update: if isSignedIn() && isValidId(evalId)
                    && (isAdmin() || existing().userId == request.auth.uid)
                    && isValidPostpartumEvaluation(incoming())
                    && incoming().userId == existing().userId
                    && incoming().createdAt == existing().createdAt;
      allow delete: if isSignedIn() && (isAdmin() || existing().userId == request.auth.uid) && isValidId(evalId);
    }
  }
}
